# M2V Web 服务 Dockerfile
# 用于 API Server + Celery Worker
FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/app/models

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-distutils \
    ffmpeg \
    libsndfile1 \
    git \
    curl \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# Bootstrap pip for python3.11 via get-pip.py
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python \
    && python -m pip install --no-cache-dir --upgrade pip setuptools wheel

WORKDIR /app

# PyTorch (CUDA 12.6)
RUN python -m pip install --no-cache-dir \
    torch torchaudio \
    --index-url https://download.pytorch.org/whl/cu126

# 项目依赖 (含 web extras)
COPY pyproject.toml .
RUN python -m pip install --no-cache-dir ".[web]"

# 源码
COPY src/ src/
COPY templates/ templates/
COPY assets/ assets/
COPY frontend/ frontend/

# 目录
RUN mkdir -p /app/input /app/output /app/uploads /app/models

EXPOSE 8000

# 默认启动 API Server
CMD ["python", "-m", "src.api_server"]
