# ============================================================
# M2V 环境变量配置
# 复制此文件为 .env 并修改
# ============================================================

# ── 通用 ──────────────────────────────────────────────────
DEBUG=false
# 生产环境请更换为随机字符串: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32

# ── 数据库 ────────────────────────────────────────────────
# 本地开发 (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./m2v.db
# 生产 (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://m2v:password@localhost:5432/m2v
# DB_PASSWORD=m2v_dev_password

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── 文件存储 ──────────────────────────────────────────────
# "local" 或 "s3"
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# S3 / MinIO (STORAGE_BACKEND=s3 时启用):
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=m2v
# S3_REGION=us-east-1

# ── 用户配额 ──────────────────────────────────────────────
FREE_MONTHLY_QUOTA=5
PRO_MONTHLY_QUOTA=100
MAX_UPLOAD_SIZE_MB=50

# ── 服务 ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
